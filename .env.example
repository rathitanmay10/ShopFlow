# App
ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://shopflow:shopflow@localhost:5432/shopflow
TEST_DATABASE_URL=postgresql+asyncpg://shopflow:shopflow@localhost:5432/shopflow_test

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Payment simulator
PAYMENT_SUCCESS_RATE=0.8
PAYMENT_MAX_RETRIES=3

# Rate limit
RATE_LIMIT_DEFAULT_PER_MIN=120
RATE_LIMIT_AUTH_PER_MIN=5

# Inventory
LOW_STOCK_THRESHOLD=5
